REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# Backend database settings
# Leave DATABASE_URL empty to use MySQL below.
DATABASE_URL=
USE_SQLITE_FALLBACK=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Dharani@2007
MYSQL_DATABASE=security

# Node RBAC module API URL
REACT_APP_RBAC_API_BASE_URL=http://localhost:5000/api

# Optional local custom domain for frontend dev
# Add hosts entries using: npm run domain:setup (Admin terminal)
# Then run: npm run start:domain and open http://rajafrondend:3000
FRONTEND_LOCAL_DOMAIN=rajafrondend
