APP_NAME=Crime Predictive Model & Hotspot Mapping System
API_PREFIX=/api/v1
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin@123
BOOTSTRAP_OFFICER_USERNAME=officer
BOOTSTRAP_OFFICER_PASSWORD=Officer@123

# Default local storage uses SQLite via backend/crime.db, so the backend can start without MySQL.
